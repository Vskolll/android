<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:foreground="?attr/selectableItemBackground"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardUseCompatPadding="false"
    app:strokeWidth="1dp"
    app:strokeColor="@color/neon_stroke"
    app:cardBackgroundColor="@color/glass_card_bg"
    app:rippleColor="@color/neon_ripple">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <View
                android:id="@+id/viewSeverity"
                android:layout_width="8dp"
                android:layout_height="26dp"
                android:layout_marginEnd="10dp"
                android:background="@color/status_unknown_fg"/>

            <TextView
            android:id="@+id/tvTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Bootloader / Verified Boot"
                android:textStyle="bold"
            android:textAppearance="@style/TextAppearance.MyApplication.Title"
            android:textColor="@color/text_primary"
            android:maxLines="1"
            android:ellipsize="end"/>

            <ImageView
                android:id="@+id/ivStatus"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginStart="10dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_status_warn"
                app:tint="@color/status_warn_fg"/>

            <TextView
            android:id="@+id/tvBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="WARN"
            android:textAppearance="@style/TextAppearance.MyApplication.Badge"
            android:textColor="@color/status_warn_fg"
            android:background="@drawable/bg_badge"
            android:elevation="2dp"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Недостаточно данных"
            android:textAppearance="@style/TextAppearance.MyApplication.Subtitle"
            android:textColor="@color/text_secondary"
            android:maxLines="2"
            android:ellipsize="end"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDetails"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/open_details"
            android:textAllCaps="false"
            android:minHeight="0dp"
            android:minWidth="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:paddingHorizontal="10dp"
            android:textSize="12sp"
            app:icon="@drawable/ic_chevron_right"
            app:iconPadding="6dp"
            app:iconGravity="textStart"
            app:iconSize="16dp"
            app:backgroundTint="@android:color/transparent"
            android:textColor="@color/text_primary"
            app:rippleColor="@android:color/transparent"/>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
